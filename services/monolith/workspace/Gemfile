gem "dotenv"

group :development do
  gem "hanami-webconsole", "~> 2.3.1"
  # Pinned to match the version used to commit checked-in stubs.
  # Different grpc-tools versions emit different `R<jsonName>` annotations
  # in the descriptor blob, causing spurious churn on `bin/codegen`.
  # 1.81.1 is the minimum that supports Ruby 4.0 (earlier versions cap at
  # `< 3.5.dev` on Linux platform gemspecs).
  gem "grpc-tools", "1.81.1"
end

group :development, :test do
  gem "faker", "~> 3.8"
end

group :cli, :development do
  gem "hanami-reloader", "~> 2.3.0"
end

group :cli, :development, :test do
  gem "hanami-rspec", "~> 2.3.1"
end

group :test do
  # Database
  gem "database_cleaner-sequel"

  # Web integration
  gem "capybara"
  gem "rack-test"
end
